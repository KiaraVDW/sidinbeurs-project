@model SidInBeurs.Controllers.LoginInput
@{
    ViewData["Title"] = "Aanmelden";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="bg-white border rounded-3 p-4">
            <h1 class="h3 mb-3">Aanmelden</h1>
            <form method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">E-mail</label>
                    <input asp-for="Email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Wachtwoord</label>
                    <input asp-for="Password" type="password" class="form-control" />
                </div>
                <button class="btn btn-primary w-100">Aanmelden</button>
            </form>
        </div>
    </div>
</div>
