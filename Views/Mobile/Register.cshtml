@model SidInBeurs.Controllers.MobileRegistrationInput
@{
    ViewData["Title"] = "Mobiele registratie";
}

<div class="mobile-shell mx-auto">
    <h1 class="h3 mb-3">Interesse registreren</h1>
    @if (TempData["Success"] is not null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    <form method="post" class="bg-white border rounded-3 p-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-2">
            <div class="col-12">
                <label asp-for="VisitorCode" class="form-label">Bezoeker ID</label>
                <input asp-for="VisitorCode" class="form-control" readonly />
            </div>
            <div class="col-6">
                <label asp-for="FirstName" class="form-label">Voornaam</label>
                <input asp-for="FirstName" class="form-control" />
            </div>
            <div class="col-6">
                <label asp-for="LastName" class="form-label">Achternaam</label>
                <input asp-for="LastName" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="BirthDate" class="form-label">Geboortedatum</label>
                <input asp-for="BirthDate" type="date" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="CurrentSchool" class="form-label">Huidige onderwijsinstelling</label>
                <input asp-for="CurrentSchool" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="CurrentStudyArea" class="form-label">Huidig studiegebied</label>
                <input asp-for="CurrentStudyArea" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="FairId" class="form-label">Beurs</label>
                <select asp-for="FairId" class="form-select">
                    @foreach (var fair in Model.Fairs)
                    {
                        <option value="@fair.Id">@fair.Name - @fair.City</option>
                    }
                </select>
            </div>
        </div>
        <hr />
        <label class="form-label">Opleidingen</label>
        <span asp-validation-for="SelectedProgramIds" class="text-danger d-block"></span>
        <div class="row g-2">
            @foreach (var program in Model.Programs)
            {
                <div class="col-12">
                    <label class="form-check-card d-flex gap-2">
                        <input class="form-check-input" type="checkbox" name="SelectedProgramIds" value="@program.Id" checked="@Model.SelectedProgramIds.Contains(program.Id)" />
                        <span><strong>@program.Name</strong><br /><span class="text-muted">@program.Faculty</span></span>
                    </label>
                </div>
            }
        </div>
        <div class="mt-3">
            <label asp-for="Notes" class="form-label">Opmerkingen</label>
            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        </div>
        <button class="btn btn-primary btn-lg w-100 mt-3">Opslaan</button>
    </form>
</div>
